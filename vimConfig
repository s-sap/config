colorscheme industry
syntax on

set cursorline
set background=dark
set linebreak
set number
set numberwidth=2
set showbreak=+++
set mouse+=a
set textwidth=100
set showmatch
set visualbell
set hlsearch
set smartcase
set ignorecase
set incsearch
set tabstop=4
set shiftwidth=4
set softtabstop=4
set expandtab
set ruler
set undolevels=999
set backspace=indent,eol,start

" BackGround
highlight Normal ctermbg=232
" Syntax
highlight NonText ctermfg=black
highlight CursorLine cterm=NONE ctermbg=234 ctermfg=NONE
highlight CursorLineNr cterm=bold ctermbg=233 ctermfg=grey
highlight LineNr term=bold cterm=NONE ctermfg=237 ctermbg=NONE guifg=DarkGrey
highlight Comment cterm=italic ctermfg=white
highlight Function cterm=bold ctermfg=12
highlight Statement cterm=italic ctermfg=177
highlight Constant ctermfg=113
highlight PreProc ctermfg=199
highlight Operator ctermfg=202
highlight Todo ctermfg=1 ctermbg=yellow
autocmd BufRead,BufNewFile * syn match parens /[()]/ | hi parens ctermfg=blue
autocmd FileType * call <SID>def_base_syntax() " autocmd Syntax may be better
function! s:def_base_syntax()
  syntax match commonOperator "\(+\|=\|-\|\^\|\*\)"
  syntax match baseDelimiter ","
  hi link commonOperator Operator
  hi link baseDelimiter Special
endfunction

" status bar colors
set laststatus=2
au InsertLeave * hi statusline ctermfg=white ctermbg=0
au InsertEnter * hi statusline ctermfg=black ctermbg=white

let g:currentmode={
    \ 'n'  : 'Normal',
    \ 'no' : 'Normal·Operator Pending',
    \ 'v'  : 'Visual',
    \ 'V'  : 'V·Line',
    \ '^V' : 'V·Block',
    \ 's'  : 'melect',
    \ 'S'  : 'S·Line',
    \ '^S' : 'S·Block',
    \ 'i'  : 'Insert',
    \ 'R'  : 'Replace',
    \ 'Rv' : 'V·Replace',
    \ 'c'  : 'Command',
    \ 'cv' : 'Vim Ex',
    \ 'ce' : 'Ex',
    \ 'r'  : 'Prompt',
    \ 'rm' : 'More',
    \ 'r?' : 'Confirm',
    \ '!'  : 'Shell',
    \ 't'  : 'Terminal'
    \}

set noshowmode
set statusline=
set statusline+=%0*\ %{toupper(g:currentmode[mode()])}\  " The current mode
set statusline+=%1*\ %<%F%m%r%h%w\                       " File path, modified, readonly, helpfile, preview
set statusline+=%3*│                                     " Separator
set statusline+=%2*\ %Y\                                 " FileType
set statusline+=%3*│
set statusline+=%2*\ %{''.(&fenc!=''?&fenc:&enc).''}
set statusline+=\ (%{&ff})
set statusline+=%=
set statusline+=%3*│
set statusline+=%1*\ ln:\ %02l/%L\ (%3p%%)\ \ |
set statusline+=%{strftime('%I:%M\ %p')}


hi User1 ctermfg=007 ctermbg=239 guibg=#4e4e4e guifg=#adadad
hi User2 ctermfg=007 ctermbg=236 guibg=#303030 guifg=#adadad
hi User3 ctermfg=236 ctermbg=236 guibg=#303030 guifg=#303030
hi User4 ctermfg=239 ctermbg=239 guibg=#4e4e4e guifg=#4e4e4e
